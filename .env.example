# Copy this file to .env and fill in values.

# App
NODE_ENV=development
PORT=3000

# Database (path to SQLite file; leave blank to use ./data/neuralswarm.db)
DATABASE_URL=

# Auth
JWT_SECRET=

# Frontend to Backend
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_KEY=

# AI Providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_URL=

# Ollama (local, no key needed — set host if non-default)
OLLAMA_HOST=http://localhost:11434
