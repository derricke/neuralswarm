# Copy this file to .env and fill in values.

# App
NODE_ENV=development
PORT=3000

# Database (path to SQLite file; leave blank to use ./data/neuralswarm.db)
DATABASE_URL=

# Auth
JWT_SECRET=

# AI Providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Ollama (local, no key needed — set host if non-default)
OLLAMA_HOST=http://localhost:11434
